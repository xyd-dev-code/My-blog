---
import { type CollectionEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import PostMeta from '~/components/PostMeta.astro';
import TOC from '~/components/TOC.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  readingTime?: string;
}

const { post, readingTime } = Astro.props;
---
<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="relative mx-auto max-w-6xl px-4 sm:px-6 py-12">
    <!-- 面包屑 -->
    <nav class="mb-8 text-xs text-ink-400">
      <a href="/" class="hover:text-sky-600">~</a>
      <span class="mx-2">/</span>
      <a href="/posts" class="hover:text-sky-600">posts</a>
      <span class="mx-2">/</span>
      <span class="text-ink-500">{post.id}</span>
    </nav>

    <div class="grid gap-12 lg:grid-cols-[1fr_16rem]">
      <div class="min-w-0">
        <header class="mb-10 pb-8 border-b border-cloud-300">
          <h1 class="font-display text-3xl sm:text-5xl font-bold text-ink-900 text-balance leading-tight">
            {post.data.title}
          </h1>
          <p class="mt-4 text-lg text-ink-500 leading-relaxed">
            {post.data.description}
          </p>
          <div class="mt-6">
            <PostMeta post={post} readingTime={readingTime} />
          </div>
        </header>

        <div class="prose-paper">
          <slot />
        </div>

        <!-- 底部：返回 -->
        <footer class="mt-16 pt-8 border-t border-cloud-300">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <a
              href="/posts"
              class="inline-flex items-center gap-2 text-sm text-ink-500 hover:text-sky-700 transition-colors"
            >
              <span>←</span> 回到所有文章
            </a>
            <div class="text-xs text-ink-400">
              ☁️ 感谢阅读到这里
            </div>
          </div>
        </footer>
      </div>

      <TOC headings={post.data.headings ?? []} />
    </div>
  </article>
</BaseLayout>
