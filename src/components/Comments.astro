---
// Giscus 评论组件
// 使用前需在 GitHub 仓库 Settings → Features 开启 Discussions
// 并安装 giscus app：https://giscus.app
// 把下面两个占位换成 giscus.app 上填出来的值
const REPO_ID = 'REPLACE_ME_GISCUS_REPO_ID';
const CATEGORY_ID = 'REPLACE_ME_GISCUS_CATEGORY_ID';
const isConfigured = !REPO_ID.startsWith('REPLACE_ME') && !CATEGORY_ID.startsWith('REPLACE_ME');

interface Props {
  slug: string;
}
const { slug } = Astro.props;
const repo = 'xyd-dev-code/My-blog';
---

<section class="mt-16 pt-8 border-t border-border-subtle">
  <h2 class="font-display text-2xl font-bold mb-6">
    <span class="text-neon-magenta font-mono">#</span>
    <span class="text-text-primary">comments</span>
  </h2>
  {isConfigured ? (
    <>
      <p class="text-text-dim font-mono text-sm mb-6">
        <span class="text-neon-cyan">$</span> git commit -m "留下你的想法" <br />
        <span class="text-text-mute">// 基于 GitHub Discussions,加载可能需要科学上网</span>
      </p>
      <script
        src="https://giscus.app/client.js"
        data-repo={repo}
        data-repo-id={REPO_ID}
        data-category="Announcements"
        data-category-id={CATEGORY_ID}
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="top"
        data-theme="light"
        data-lang="zh-CN"
        crossorigin="anonymous"
        async
      ></script>
    </>
  ) : (
    <div class="paper-card p-6 sm:p-8 text-center bg-sky-50/40 border-sky-200">
      <div aria-hidden="true" class="text-3xl mb-2">✎</div>
      <p class="text-ink-700 font-display font-medium mb-2">留言区还没配置好</p>
      <p class="text-sm text-ink-500 mb-5 max-w-md mx-auto">
        暂时请到 GitHub Discussions 直接留言 — 同样的内容,同样的线程、回复、表情反应全都在。
      </p>
      <a
        href={`https://github.com/${repo}/discussions/new?category=general`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-gradient-to-br from-sky-50 to-leaf-50 border border-sky-200 text-sm font-medium text-sky-700 hover:border-sky-400 hover:shadow-paper-md transition-[transform,box-shadow,border-color] duration-[120ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
      >
        <span aria-hidden="true">↗</span>
        去 Discussions 留言
      </a>
      <p class="text-[11px] text-ink-400 mt-4 font-mono">
        // 配置方式:见 <code class="px-1 py-0.5 rounded bg-cloud-100">src/components/Comments.astro</code> 顶部的 REPO_ID / CATEGORY_ID
      </p>
    </div>
  )}
</section>
