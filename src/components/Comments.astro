---
// Utterances 评论组件
// 零后端、零数据库、零构建配置:留言直接走 GitHub Issues,issue 标题 = 页面路径。
// 使用前需安装 utterances app:https://github.com/apps/utterances
// 装到 xyd-dev-code/My-blog 后,无需任何其他配置。
const repo = 'xyd-dev-code/My-blog';
// utterances 只需要 repo = OWNER/REPO,无需任何 token。
// 装 utterances app(https://github.com/apps/utterances)到仓库后,刷新页面即生效。
const REPO_RE = /^[A-Za-z0-9_.-]+\/[A-Za-z0-9_.-]+$/;
const isConfigured = REPO_RE.test(repo);

interface Props {
  slug: string;
}
const { slug } = Astro.props;
---

<section class="mt-16 pt-8 border-t border-border-subtle">
  <h2 class="font-display text-2xl font-bold mb-6">
    <span class="text-neon-magenta font-mono">#</span>
    <span class="text-text-primary">comments</span>
  </h2>
  {isConfigured ? (
    <>
      <p class="text-text-dim font-mono text-sm mb-6">
        <span class="text-neon-cyan">$</span> git commit -m "留下你的想法" <br />
        <span class="text-text-mute">// 基于 GitHub Issues,加载可能需要科学上网</span>
      </p>
      <script
        src="https://utteranc.es/client.js"
        repo={repo}
        issue-term={slug}
        label="guestbook"
        theme="github-light"
        crossorigin="anonymous"
        async
      ></script>
    </>
  ) : (
    <div class="paper-card p-6 sm:p-8 text-center bg-sky-50/40 border-sky-200">
      <div aria-hidden="true" class="text-3xl mb-2">✎</div>
      <p class="text-ink-700 font-display font-medium mb-2">留言区还没配置好</p>
      <p class="text-sm text-ink-500 mb-5 max-w-md mx-auto">
        请先去 <a href="https://github.com/apps/utterances" target="_blank" rel="noopener noreferrer" class="text-sky-600 hover:underline">utterances app</a> 装到 <code class="px-1 py-0.5 rounded bg-cloud-100 font-mono text-xs">xyd-dev-code/My-blog</code>,装完刷新页面即可。
      </p>
    </div>
  )}
</section>
