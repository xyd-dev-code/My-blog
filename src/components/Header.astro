---
import { NAV, SITE } from '~/consts';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href + '/');
};
---
<header
  class="sticky top-0 z-50 border-b border-cloud-300/60 backdrop-blur-md bg-white/70"
>
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <!-- Logo -->
    <a href="/" class="group flex items-center gap-2.5">
      <img
        src={SITE.avatar}
        alt={SITE.author}
        class="h-7 w-7 rounded-full object-cover shadow-paper"
        onerror="this.onerror=null;this.outerHTML='<span class=&quot;inline-block h-7 w-7 rounded-full shadow-paper&quot; style=&quot;background: linear-gradient(135deg, #38bdf8 0%, #0ea5e9 60%, #0369a1 100%);&quot;></span>'"
      />
      <span
        class="font-display text-base font-semibold tracking-tight text-ink-900 group-hover:text-sky-700 transition-[color] duration-[120ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
      >
        {SITE.author}
      </span>
    </a>

    <!-- 桌面导航 -->
    <nav class="hidden md:flex items-center gap-1">
      {NAV.map((item) => (
        <a
          href={item.href}
          class:list={[
            'px-3 py-1.5 text-sm font-medium rounded-md transition-[color,background-color] duration-[120ms] ease-[cubic-bezier(0.22,1,0.36,1)]',
            isActive(item.href)
              ? 'text-sky-700 bg-sky-50'
              : 'text-ink-500 hover:text-ink-900 hover:bg-cloud-100',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- 右侧：GitHub + 移动端汉堡 -->
    <div class="flex items-center gap-2">
      <a
        href={SITE.github}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:inline-flex h-9 w-9 items-center justify-center rounded-full text-ink-500 hover:text-sky-600 hover:bg-sky-50 transition-[color,background-color] duration-[120ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
        aria-label="GitHub"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.17c-3.34.73-4.04-1.41-4.04-1.41-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.34-5.47-5.96 0-1.32.47-2.39 1.24-3.23-.13-.3-.54-1.52.11-3.17 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.65.24 2.87.12 3.17.77.84 1.24 1.91 1.24 3.23 0 4.63-2.81 5.65-5.49 5.95.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 24 12c0-6.63-5.37-12-12-12Z"/>
        </svg>
      </a>

      <details class="md:hidden relative">
        <summary class="list-none cursor-pointer h-9 w-9 flex items-center justify-center rounded-full text-ink-500 hover:text-sky-600 hover:bg-sky-50">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </summary>
        <nav class="absolute right-0 mt-2 w-44 rounded-xl border border-cloud-300 bg-white p-2 shadow-paper-md">
          {NAV.map((item) => (
            <a
              href={item.href}
              class:list={[
                'block px-3 py-2 text-sm rounded-lg transition-[color,background-color] duration-[120ms] ease-[cubic-bezier(0.22,1,0.36,1)]',
                isActive(item.href) ? 'text-sky-700 bg-sky-50' : 'text-ink-500 hover:text-ink-900 hover:bg-cloud-100',
              ]}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </details>
    </div>
  </div>
</header>
