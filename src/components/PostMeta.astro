---
import { type CollectionEntry } from 'astro:content';
import { formatDate } from '~/utils/date';

interface Props {
  post: CollectionEntry<'posts'>;
  readingTime?: string;
}

const { post, readingTime } = Astro.props;
const tags = post.data.tags ?? [];
---
<div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-ink-500">
  <div class="flex items-center gap-1.5">
    <svg class="h-4 w-4 text-sky-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
      <line x1="16" y1="2" x2="16" y2="6"/>
      <line x1="8" y1="2" x2="8" y2="6"/>
      <line x1="3" y1="10" x2="21" y2="10"/>
    </svg>
    <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
    {post.data.updatedDate && (
      <span class="text-ink-400">
        (更新于 {formatDate(post.data.updatedDate)})
      </span>
    )}
  </div>

  {readingTime && (
    <div class="flex items-center gap-1.5">
      <svg class="h-4 w-4 text-sun-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/>
        <polyline points="12 6 12 12 16 14"/>
      </svg>
      <span>{readingTime}</span>
    </div>
  )}

  {tags.length > 0 && (
    <div class="flex items-center gap-1.5 flex-wrap">
      {tags.map((t, i) => (
        <a
          href={`/tags/${t}`}
          class:list={[
            'tag-chip',
            i % 3 === 1 ? 'tag-chip-warm' : i % 3 === 2 ? 'tag-chip-leaf' : '',
          ]}
        >
          #{t}
        </a>
      ))}
    </div>
  )}
</div>
