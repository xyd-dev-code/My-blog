---
import { type CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'posts'>;
}

const { project } = Astro.props;
const data = project.data;
import { filterTags } from '~/consts';

// ... existing code ...

const tags = filterTags(data.tags ?? []);
---

<a
  href={`/posts/${project.id}`}
  data-tilt
  class="paper-card group block overflow-hidden transition-[transform] duration-[220ms] ease-[cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-1 relative"
>
  <div class="h-40 relative overflow-hidden bg-cloud-200">
    {data.cover && (
      <img
        src={data.cover}
        alt={data.title}
        loading="eager"
        decoding="async"
        referrerpolicy="no-referrer"
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
      />
    )}

    <div class="absolute top-3 left-3">
      <span class="tag-chip bg-white/90 text-sky-700">
        {project.id === 'project-retro' ? '⭐ featured' : '项目'}
      </span>
    </div>
  </div>

  <div class="p-5">
    <h3 class="font-display text-lg font-semibold text-ink-900 group-hover:text-sky-700 transition-[color] duration-[120ms] ease-[cubic-bezier(0.22,1,0.36,1)]">
      {data.title}
    </h3>
    <p class="mt-2 text-sm text-ink-500 line-clamp-2 leading-relaxed">
      {data.description}
    </p>
    {tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-1.5">
        {tags.slice(0, 4).map((t, i) => (
          <span
            class:list={[
              'tag-chip',
              i % 3 === 1 ? 'tag-chip-warm' : i % 3 === 2 ? 'tag-chip-leaf' : '',
            ]}
          >
            #{t}
          </span>
        ))}
      </div>
    )}
  </div>
</a>
