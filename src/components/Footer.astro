---
import { SITE, SOCIALS } from '~/consts';
const year = new Date().getFullYear();
---
<footer class="mt-0 border-t border-cloud-300/60">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-10">
    <div class="grid gap-8 sm:grid-cols-3">
      <!-- 站点信息 -->
      <div class="flex flex-col justify-end self-end">
        <div class="flex items-center gap-2 mb-3">
          <span
            class="inline-block h-5 w-5 rounded-full shadow-paper"
            style="background: linear-gradient(135deg, #38bdf8 0%, #0ea5e9 60%, #0369a1 100%);"
          ></span>
          <span class="font-display text-sm font-semibold text-ink-900">
            {SITE.author}
          </span>
        </div>
        <p class="text-sm text-ink-500 leading-relaxed">
          {SITE.description}
        </p>
      </div>

      <!-- 社交链接 -->
      <div class="flex flex-col justify-end self-end">
        <h3 class="font-mono text-xs uppercase tracking-widest text-ink-400 mb-3">
          // links
        </h3>
        <ul class="space-y-2 text-sm">
          {SOCIALS.map((s) => (
            <li>
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                class="underline-link"
              >
                → {s.label}
              </a>
            </li>
          ))}
          <li>
            <a href={SITE.repo} target="_blank" rel="noopener noreferrer" class="underline-link">
              → Source Code
            </a>
          </li>
          <li>
            <a href="/rss.xml" class="underline-link">→ RSS Feed</a>
          </li>
        </ul>
      </div>

      <!-- 技术栈 -->
      <div class="flex flex-col justify-end self-end">
        <h3 class="font-mono text-xs uppercase tracking-widest text-ink-400 mb-3">
          // built with
        </h3>
        <ul class="space-y-1.5 text-sm text-ink-500 font-mono">
          <li><span class="text-sky-600">▸</span> Astro 5</li>
          <li><span class="text-sun-500">▸</span> Tailwind CSS</li>
          <li><span class="text-leaf-500">▸</span> TypeScript</li>
          <li><span class="text-sky-600">▸</span> Shiki / MDX</li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-cloud-300/60 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-ink-400 font-mono">
      <span>© {year} {SITE.author}. All rights reserved.</span>
      <span>
        <span class="text-leaf-500">●</span> deployed via GitHub Actions
      </span>
    </div>
  </div>
</footer>
