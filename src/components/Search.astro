---
// Pagefind 搜索组件：构建时由 pagefind 注入 index
// 运行时查找页面上的 #search 输入框并显示结果
---
<link
  href="/pagefind/pagefind-ui.css"
  rel="stylesheet"
/>

<div id="search" class="hidden"></div>

<button
  id="search-toggle"
  type="button"
  aria-label="Search"
  class="fixed bottom-6 right-6 z-40 h-12 w-12 rounded-full bg-white shadow-paper-md border border-cloud-300 flex items-center justify-center text-sky-600 hover:shadow-paper-hover hover:bg-sky-50 transition-[transform,box-shadow,background-color] duration-[220ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
    <circle cx="11" cy="11" r="8"/>
    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
  </svg>
</button>

<div
  id="search-modal"
  class="fixed inset-0 z-50 hidden items-start justify-center pt-24 px-4 bg-sky-900/30 backdrop-blur-sm"
>
  <div class="w-full max-w-2xl rounded-2xl border border-cloud-300 bg-white shadow-paper-lg overflow-hidden">
    <div class="flex items-center justify-between border-b border-cloud-300 px-4 py-2 text-xs text-ink-500">
      <span>// search</span>
      <button id="search-close" class="hover:text-sky-600">esc</button>
    </div>
    <div id="search-container" class="p-4"></div>
  </div>
</div>

<script>
  // modal 开启/关闭 — 无论 dev 还是 prod 都能用,只跟 pagefind 是否注入 UI 有关
  const modal = document.getElementById('search-modal');
  const toggle = document.getElementById('search-toggle');
  const close = document.getElementById('search-close');
  const escLabel = modal?.querySelector('.text-ink-500 span');

  let pagefindReady = false;
  let pagefindFailed = false;

  const show = () => {
    if (!modal) return;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    const input = modal.querySelector('input');
    if (input) setTimeout(() => input.focus(), 50);
    else if (pagefindFailed) showDevNotice();
  };
  const hide = () => {
    if (!modal) return;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  };
  const showDevNotice = () => {
    const c = document.getElementById('search-container');
    if (!c || c.dataset.devMode) return;
    c.dataset.devMode = '1';
    c.innerHTML = `
      <div class="px-1">
        <div class="relative">
          <input id="client-search-input" type="text" placeholder="搜索 标题 / 描述 / 标签…" autocomplete="off" class="w-full pl-9 pr-3 py-2 text-sm rounded-md border border-cloud-300 bg-white placeholder:text-ink-400 focus:outline-none focus:border-sky-400 focus:ring-1 focus:ring-sky-200 transition-colors" />
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-ink-400 pointer-events-none"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
        </div>
        <p class="mt-2 text-[11px] text-ink-400"><span class="inline-block px-1.5 py-0.5 rounded bg-sky-50 border border-sky-200 text-sky-700 font-mono">DEV</span> 客户端索引(本地静态),生产会用 Pagefind 全站搜索。</p>
        <div id="client-search-results" class="mt-3 space-y-1.5 max-h-[55vh] overflow-y-auto"></div>
      </div>
    `;
    wireClientSearch();
  };

  // 加载一次,缓存到 window
  let searchDataPromise: Promise<{t:string;d:string;tags:string[];url:string;pubDate:string;cover:string}[]> | null = null;
  const loadSearchData = () => {
    if (searchDataPromise) return searchDataPromise;
    searchDataPromise = fetch('/search-index.json').then((r) => r.json());
    return searchDataPromise;
  };

  const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

  const wireClientSearch = () => {
    const input = document.getElementById('client-search-input') as HTMLInputElement | null;
    const out = document.getElementById('client-search-results');
    if (!input || !out) return;
    let dataPromise: Promise<{t:string;d:string;tags:string[];url:string}[]> | null = null;

    const run = async () => {
      const q = input.value.trim().toLowerCase();
      if (!q) { out!.innerHTML = '<p class="text-xs text-ink-400 py-3 text-center">输入关键字开始搜索</p>'; return; }
      dataPromise = dataPromise || loadSearchData();
      const data = await dataPromise!;
      const matched = data
        .map((p) => {
          const inT = p.t.toLowerCase().includes(q) ? 3 : 0;
          const inD = p.d.toLowerCase().includes(q) ? 2 : 0;
          const inTags = p.tags.some((t) => t.toLowerCase().includes(q)) ? 1 : 0;
          return { p, score: inT + inD + inTags };
        })
        .filter((x) => x.score > 0)
        .sort((a, b) => b.score - a.score)
        .slice(0, 12);

      if (!matched.length) {
        out!.innerHTML = '<p class="text-xs text-ink-400 py-3 text-center">无匹配结果</p>';
        return;
      }
      out!.innerHTML = matched.map(({ p }) =>
        `<a href="${p.url}" class="block group px-3 py-2 rounded-md hover:bg-sky-50 transition-colors">
          <p class="text-sm font-medium text-ink-900 group-hover:text-sky-700 leading-snug">${esc(p.t)}</p>
          <p class="text-[11px] text-ink-400 mt-0.5 line-clamp-1">${esc(p.d)}</p>
          <p class="text-[10px] text-ink-400 mt-0.5">${p.tags.slice(0,3).map((t) => '#' + esc(t)).join(' ')}</p>
        </a>`
      ).join('');
    };

    input.addEventListener('input', run);
    run();
    setTimeout(() => input.focus(), 60);
  };

  // 立即绑定 UI 事件,跟 pagefind 是否加载无关
  if (toggle) toggle.addEventListener('click', show);
  if (close) close.addEventListener('click', hide);
  if (modal) modal.addEventListener('click', (e) => e.target === modal && hide());
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') hide();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      show();
    }
  });

  // 异步加载 pagefind UI(只在 build 后存在)
  (async function tryLoadPagefind() {
    try {
      const path = ['/pagefind/', 'pagefind.', 'js'].join('');
      const mod = await import(/* @vite-ignore */ path);
      const pagefind = mod.default ?? mod;
      if (!pagefind || !pagefind.options) throw new Error('no pagefind');

      await pagefind.options({ excerptLength: 30 });
      const container = document.getElementById('search-container');
      if (!container) throw new Error('no container');
      if (container.dataset.devNotice) container.innerHTML = ''; // 清掉 dev 提示,如果有

      new pagefind.PagefindUI({
        element: container,
        showImages: false,
        showEmptyFilters: false,
        resetStyles: false,
        autofocus: true,
      });
      pagefindReady = true;
      if (escLabel) escLabel.textContent = '// ready';
    } catch {
      pagefindFailed = true;
      if (escLabel) escLabel.textContent = '// dev';
    }
  })();
</script>
