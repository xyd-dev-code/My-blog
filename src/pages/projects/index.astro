---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ProjectCard from '~/components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('projects'))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.pubDate.getTime() - a.data.pubDate.getTime();
  });

const PROJECTS_PER_PAGE = 6;
const totalPages = Math.max(1, Math.ceil(all.length / PROJECTS_PER_PAGE));
const rawPage = Astro.url.searchParams.get('page');
const currentPage = rawPage ? Math.min(Math.max(1, Number(rawPage)), totalPages) : 1;
const projects = all.slice((currentPage - 1) * PROJECTS_PER_PAGE, currentPage * PROJECTS_PER_PAGE);

const pageHref = (n: number) => n === 1 ? '/projects' : `/projects?page=${n}`;

// 生成分页页码数组
function getPageNumbers(current: number, total: number): (number | '...')[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
  const pages: (number | '...')[] = [];
  pages.push(1);
  if (current > 3) pages.push('...');
  const start = Math.max(2, current - 1);
  const end = Math.min(total - 1, current + 1);
  for (let i = start; i <= end; i++) pages.push(i);
  if (current < total - 2) pages.push('...');
  pages.push(total);
  return pages;
}
---
<BaseLayout title="Projects" description="我做过的、正在做的项目。">
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-8 sm:py-12">
    <header class="mb-8 sm:mb-12 text-center">
      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-bold text-ink-900">
        我的项目
      </h1>
      <p class="mt-3 text-sm text-ink-500 font-serif italic max-w-xl mx-auto">
        我做过的、正在做的项目。点进任意卡片看技术细节、踩坑实录、数据复盘。
      </p>
      <p class="mt-2 text-xs text-ink-400">
        <span class="text-leaf-500">●</span> {all.length} project{all.length === 1 ? '' : 's'} found
        <span class="mx-1.5 text-ink-300">·</span>
        <span class="font-mono tabular-nums">{currentPage} / {totalPages}</span>
      </p>
    </header>

    {projects.length > 0 ? (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {projects.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    ) : (
      <div class="paper-card p-12 text-center">
        <p class="text-ink-500">
          暂无项目，先去看看 <a href="/posts" class="paper-link">文章列表</a>？
        </p>
      </div>
    )}

    <nav class="flex items-center justify-center gap-1.5 text-sm py-8">
      <!-- 左箭头 -->
      {currentPage > 1 ? (
        <a href={pageHref(currentPage - 1)} title="上一页"
           class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-cloud-300 text-ink-600 hover:border-sky-400 hover:text-sky-700 transition-colors">←</a>
      ) : (
        <span class="w-8 h-8 flex items-center justify-center rounded-lg text-ink-300 cursor-not-allowed">←</span>
      )}

      <!-- 页码 -->
      {getPageNumbers(currentPage, totalPages).map((p) =>
        p === '...' ? (
          <span class="w-8 h-8 flex items-center justify-center text-ink-400">…</span>
        ) : p === currentPage ? (
          <span class="w-8 h-8 flex items-center justify-center rounded-lg bg-sky-500 text-white font-medium">{p}</span>
        ) : (
          <a href={pageHref(p)} class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-cloud-300 text-ink-600 hover:border-sky-400 hover:text-sky-700 transition-colors">{p}</a>
        )
      )}

      <!-- 右箭头 -->
      {currentPage < totalPages ? (
        <a href={pageHref(currentPage + 1)} title="下一页"
           class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-cloud-300 text-ink-600 hover:border-sky-400 hover:text-sky-700 transition-colors">→</a>
      ) : (
        <span class="w-8 h-8 flex items-center justify-center rounded-lg text-ink-300 cursor-not-allowed">→</span>
      )}
    </nav>
  </section>
</BaseLayout>
