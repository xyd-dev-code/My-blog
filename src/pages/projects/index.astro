---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ProjectCard from '~/components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('posts', ({ data }) => !data.draft && data.tags.includes('project')))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<BaseLayout title="Projects" description="我做过的、正在做的项目。">
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-12">
    <header class="mb-12 text-center">
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-ink-900">
        我的项目
      </h1>
      <p class="mt-3 text-sm text-ink-500 font-serif italic max-w-xl mx-auto">
        我做过的、正在做的项目。点进任意卡片看技术细节、踩坑实录、数据复盘。
      </p>
      <p class="mt-2 text-xs text-ink-400">
        <span class="text-leaf-500">●</span> {projects.length} project{projects.length === 1 ? '' : 's'} found
      </p>
    </header>

    {projects.length > 0 ? (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {projects.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    ) : (
      <div class="paper-card p-12 text-center">
        <p class="text-ink-500">
          暂无 project 标签的文章，去 <a href="/posts" class="paper-link">/posts</a> 看看？
        </p>
      </div>
    )}
  </section>
</BaseLayout>
