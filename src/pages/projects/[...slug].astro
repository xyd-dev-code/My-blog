---
import { getCollection, getEntry, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await render(project);
const data = project.data;

const fmt = (d: Date) => d.toISOString().slice(0, 10);
const relatedEntries = (
  await Promise.all((data.relatedPosts ?? []).map((id) => getEntry('posts', id)))
).filter((p): p is CollectionEntry<'posts'> => Boolean(p));
---

<BaseLayout title={data.title} description={data.description} ogImage={data.cover}>
  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-6 sm:py-10">
    <!-- 面包屑 -->
    <nav class="mb-6 sm:mb-8 flex items-center gap-1.5 text-xs text-ink-500 font-mono">
      <a href="/" class="hover:text-sky-700 transition-colors">~</a>
      <span class="text-ink-300">/</span>
      <a href="/projects" class="hover:text-sky-700 transition-colors">projects</a>
      <span class="text-ink-300">/</span>
      <span class="text-ink-700 truncate">{project.id}</span>
    </nav>

    <!-- 头部：标题 + meta + cover -->
    <header class="mb-8 sm:mb-10">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        {data.featured && <span class="tag-chip bg-amber-100 text-amber-700">⭐ featured</span>}
        {data.tags.map((t) => <span class="tag-chip">#{t}</span>)}
      </div>
      <h1 class="font-display text-2xl sm:text-3xl md:text-4xl font-bold text-ink-900 leading-tight">
        {data.title}
      </h1>
      <p class="mt-3 text-base sm:text-lg text-ink-500 leading-relaxed font-serif italic">
        {data.description}
      </p>
      <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-ink-500 font-mono">
        <span>📅 {fmt(data.pubDate)}{data.endDate ? ` — ${fmt(data.endDate)}` : ''}</span>
        {data.repo && (
          <a href={data.repo} target="_blank" rel="noopener" class="paper-link inline-flex items-center gap-1">
            <span>🔗</span>
            <span>GitHub</span>
          </a>
        )}
      </div>

      {data.cover && (
        <img
          src={data.cover}
          alt={data.title}
          loading="eager"
          decoding="async"
          referrerpolicy="no-referrer"
          class="mt-6 sm:mt-8 w-full rounded-2xl shadow-sm object-cover max-h-[420px]"
        />
      )}
    </header>

    <!-- 正文 -->
    <article class="prose prose-sky max-w-none">
      <Content />
    </article>

    <!-- 相关日志 -->
    {relatedEntries.length > 0 && (
      <aside class="mt-12 sm:mt-16 pt-8 border-t border-cloud-300">
        <h2 class="font-display text-xl sm:text-2xl font-semibold text-ink-900 mb-4 sm:mb-6">
          📓 相关日志
        </h2>
        <ul class="grid gap-3 sm:gap-4 sm:grid-cols-2">
          {relatedEntries.map((p) => (
            <li>
              <a
                href={`/posts/${p.id}`}
                class="paper-card group block p-4 sm:p-5 transition-colors hover:border-sky-300"
              >
                <div class="flex items-baseline justify-between gap-3">
                  <span class="text-xs font-mono text-ink-400 tabular-nums">
                    {fmt(p.data.pubDate)}
                  </span>
                  <span class="tag-chip text-[10px]">post</span>
                </div>
                <h3 class="mt-2 font-display text-base font-medium text-ink-800 group-hover:text-sky-700 transition-colors leading-snug line-clamp-2">
                  {p.data.title}
                </h3>
                <p class="mt-1.5 text-xs text-ink-500 line-clamp-2 leading-relaxed">
                  {p.data.description}
                </p>
              </a>
            </li>
          ))}
        </ul>
      </aside>
    )}

    <!-- 返回 -->
    <div class="mt-10 sm:mt-12 text-center">
      <a href="/projects" class="paper-link text-sm">← 回到项目列表</a>
    </div>
  </section>
</BaseLayout>