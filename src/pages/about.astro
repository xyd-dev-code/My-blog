---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SITE } from '~/consts';

const skills = {
  languages: ['TypeScript', 'JavaScript', 'Java', 'Python', 'SQL', 'Bash'],
  frontend: ['Vue 3', 'React 19', 'Astro', 'Tailwind CSS', 'Vite', 'Naive UI', 'Element Plus'],
  backend: ['Spring Boot 3', 'Node.js (Nest)', 'MyBatis-Plus', 'JPA', 'JWT', 'REST'],
  data: ['MySQL 8', 'PostgreSQL', 'Redis', 'Elasticsearch'],
  devops: ['Docker', 'Docker Compose', 'GitHub Actions', 'Nginx', 'Linux', 'PM2'],
  tools: ['VS Code', 'Git', 'pnpm', 'Vite', 'Vitest', 'Playwright'],
};

const timeline = [
  { year: '2026', title: 'zhikao-cloud 上线', detail: '从 0 到 1 搭建全栈应用，覆盖 200+ 用户' },
  { year: '2025', title: '主攻后端工程化', detail: 'Spring Boot 3 + JDK 21 + MyBatis-Plus' },
  { year: '2024', title: '前端工程化转型', detail: '从 jQuery 切到 Vue 3 + TypeScript' },
  { year: '2023', title: '开始写技术博客', detail: '在语雀、Notion 上零星记录' },
];
---
<BaseLayout title="About" description={`关于 ${SITE.author}。`}>
  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-12">
    <header class="mb-12 text-center">
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-ink-900">
        关于我
      </h1>
      <p class="mt-3 text-sm text-ink-500 font-serif italic">
        about me
      </p>
    </header>

    <!-- 自我介绍卡片 -->
    <div class="paper-card p-8 mb-12">
      <div class="prose-paper">
        <p>
          我是 <strong class="text-sky-700">{SITE.author}</strong>，全栈工程师，主业写 Java / Vue，业余折腾个人项目。
        </p>
        <p>
          现在手上最大的项目是 <a href="/posts/project-retro" class="paper-link">zhikao-cloud</a>——一个面向学生的在线考试 + 学习平台，
          Spring Boot 3 + Vue 3 + Docker 一键起，跑了一年多，200 多个真实用户。
          中间踩过的坑、为什么这么选型、哪些地方翻车了，全都写进了
          <a href="/posts/project-retro" class="paper-link">那篇复盘</a>。
        </p>
        <p>
          这个博客是我的外接硬盘——学新东西的笔记、做项目的复盘、踩过的坑、偶尔的小工具。
          不写鸡汤、不抄文档，只写我真正动手做过的事。
          如果你也在学类似的东西，希望这里能省你一两个小时。
        </p>
      </div>

      <div class="mt-6 pt-6 border-t border-cloud-300 flex flex-wrap items-center gap-4 text-sm">
        <a href={SITE.github} target="_blank" rel="noopener" class="paper-link font-medium">
          → GitHub @xyd-dev-code
        </a>
        <span class="text-ink-300">·</span>
        <span class="text-ink-500">x2597486661 [at] gmail.com</span>
      </div>
    </div>

    <!-- 技能树 -->
    <h2 class="font-display text-2xl font-bold mb-6 mt-16 text-ink-900">
      <span class="text-sky-600">#</span> 技能树
    </h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {Object.entries(skills).map(([category, items], idx) => (
        <div class="paper-card p-5">
          <h3 class="text-xs font-mono uppercase tracking-widest text-sky-700 mb-3">
            // {category}
          </h3>
          <div class="flex flex-wrap gap-1.5">
            {items.map((item, i) => (
              <span
                class:list={[
                  'tag-chip',
                  i % 3 === 1 ? 'tag-chip-warm' : i % 3 === 2 ? 'tag-chip-leaf' : '',
                ]}
              >
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- 时间线 -->
    <h2 class="font-display text-2xl font-bold mb-6 mt-16 text-ink-900">
      <span class="text-sky-600">#</span> 时间线
    </h2>
    <ol class="relative border-l-2 border-cloud-300 pl-6 space-y-8">
      {timeline.map((item) => (
        <li class="relative">
          <span
            class="absolute -left-[33px] top-1.5 h-3 w-3 rounded-full bg-sky-500 ring-4 ring-white"
          ></span>
          <div class="text-sm text-sky-700 font-medium">{item.year}</div>
          <h3 class="font-display text-lg font-semibold text-ink-900 mt-1">
            {item.title}
          </h3>
          <p class="text-ink-500 text-sm mt-1">{item.detail}</p>
        </li>
      ))}
    </ol>

    <!-- 联系 CTA -->
    <div class="mt-16 paper-card p-8 text-center bg-gradient-to-br from-sky-50 to-white">
      <p class="text-ink-700">
        <span class="text-sky-600 font-medium">如果你觉得我还行</span>：
      </p>
      <p class="mt-3 text-lg">
        <a href={SITE.github} target="_blank" rel="noopener" class="paper-link font-semibold">
          GitHub @xyd-dev-code
        </a>
      </p>
      <p class="mt-2 text-xs text-ink-400">
        欢迎约技术交流 / 互相推荐工具
      </p>
    </div>
  </section>
</BaseLayout>
