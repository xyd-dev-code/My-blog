---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SITE } from '~/consts';

const email = 'x2597486661@gmail.com';
---
<BaseLayout
  title="About"
  description={`${SITE.author} — 在一家行业软件公司做后端，写代码也写心得。`}
>
  <section class="mx-auto max-w-3xl px-4 sm:px-6 py-16 sm:py-24">
    <header class="text-center">
      <div class="mx-auto w-16 h-16 rounded-full bg-gradient-to-br from-sky-300 to-sky-500 ring-2 ring-white shadow-sm"></div>
      <h1 class="mt-5 font-display text-3xl sm:text-4xl font-bold tracking-tight text-ink-900">
        {SITE.author}
      </h1>
      <p class="mt-2 font-serif italic text-base text-ink-500">
        后端偏重的全栈工程师。
      </p>
    </header>

    <article class="mt-12 paper-card p-6 sm:p-8 md:p-10">
      <section>
        <h2 class="font-display text-lg font-semibold text-ink-900">我是谁</h2>
        <p class="mt-2 text-base text-ink-700 leading-relaxed">
          现在在一家行业软件公司做业务支撑系统的后端，给 zhikao-cloud 加新功能，业余写这个博客。写过 Java Web、电商、在线考试——具体能在 <a href="/projects" class="paper-link">项目页</a> 看到。
        </p>
      </section>

      <section class="mt-7">
        <h2 class="font-display text-lg font-semibold text-ink-900">现在在做什么</h2>
        <p class="mt-2 text-base text-ink-700 leading-relaxed">
          白天改生产 SQL、跟导师过 user 模块；晚上回来敲 zhikao-cloud 的下一版 schema，再给博客写一篇。偶尔摸鱼写一份「全栈开发者路线地图」——把踩过的坑串成一条线。
        </p>
      </section>

      <section class="mt-7">
        <h2 class="font-display text-lg font-semibold text-ink-900">我的写法</h2>
        <p class="mt-2 text-base text-ink-700 leading-relaxed">
          相信代码要可读、文档要清晰、一致性比 hot take 更值钱。AI 工具能提速但不能替你判断——所以关键设计我会慢下来想。
        </p>
      </section>

      <!-- 卡内末尾联系方式，不另起 card -->
      <div class="mt-8 pt-6 border-t border-cloud-200 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
        <a
          href={SITE.github}
          target="_blank"
          rel="noopener noreferrer"
          class="paper-link font-medium inline-flex items-center gap-1 group"
        >
          → GitHub @xyd-dev-code<span class="card-arrow">↗</span>
        </a>
        <a
          href="/rss.xml"
          class="paper-link font-medium inline-flex items-center gap-1 group"
        >
          → RSS 订阅<span class="card-arrow">→</span>
        </a>
        <span class="flex items-center gap-2">
          <span class="text-ink-500 font-mono" aria-label="Email">{email}</span>
          <button
            type="button"
            id="copy-email-btn"
            class="text-xs font-mono px-2 py-0.5 rounded-md border border-cloud-300 text-ink-500 hover:text-sky-700 hover:border-sky-500 transition-[color,border-color] duration-[120ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
            data-email={email}
            aria-label="复制邮箱到剪贴板"
          >
            复制
          </button>
        </span>
      </div>
    </article>
  </section>
</BaseLayout>

<script>
  const btn = document.getElementById('copy-email-btn');
  if (btn) {
    btn.addEventListener('click', async () => {
      const email = btn.getAttribute('data-email');
      if (!email) return;
      try {
        await navigator.clipboard.writeText(email);
        const original = btn.textContent;
        btn.textContent = '已复制';
        setTimeout(() => { btn.textContent = original; }, 1500);
      } catch {
        btn.textContent = '复制失败';
        setTimeout(() => { btn.textContent = '复制'; }, 1500);
      }
    });
  }
</script>