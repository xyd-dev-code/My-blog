---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SITE } from '~/consts';

const email = 'x2597486661@gmail.com';
---
<BaseLayout
  title="About"
  description={`${SITE.author} — 在一家行业软件公司做后端，写代码也写心得。`}
>
  <section class="mx-auto max-w-3xl px-4 sm:px-6 py-16 sm:py-24">
    <header class="text-center">
      <img
        src={SITE.avatar}
        alt={SITE.author}
        class="mx-auto w-16 h-16 rounded-full object-cover ring-2 ring-white shadow-sm"
        onerror="this.onerror=null;this.outerHTML='<div class=&quot;mx-auto w-16 h-16 rounded-full bg-gradient-to-br from-sky-300 to-sky-500 ring-2 ring-white shadow-sm&quot;></div>'"
      />
      <h1 class="mt-5 font-display text-3xl sm:text-4xl font-bold tracking-tight text-ink-900">
        {SITE.author}
      </h1>
      <p class="mt-2 font-serif italic text-base text-ink-500">
        后端偏重的全栈工程师。
      </p>
    </header>

    <article class="mt-12 paper-card p-6 sm:p-8 md:p-10">
      <p class="font-mono text-xs uppercase tracking-widest text-sky-700 mb-4">
        // about.me
      </p>

      <dl class="font-mono text-sm leading-7">
        <div class="grid grid-cols-[8rem_1fr] gap-x-3">
          <dt class="text-ink-400 select-none">now_editing</dt>
          <dd class="text-ink-900">
            <a href="/posts" class="text-sky-700 hover:text-sky-600 transition-[color] duration-[120ms]">blog</a>,
            <a href="/projects" class="text-sky-700 hover:text-sky-600 transition-[color] duration-[120ms]">projects</a>,
            <a href="https://github.com/xyd-dev-code" target="_blank" rel="noopener" class="text-sky-700 hover:text-sky-600 transition-[color] duration-[120ms]">side code</a>
          </dd>
        </div>
        <div class="grid grid-cols-[8rem_1fr] gap-x-3">
          <dt class="text-ink-400 select-none">main_lang</dt>
          <dd class="text-ink-900">
            Java · SQL · TypeScript
            <span class="text-ink-300 mx-1">/</span>
            Vue · Spring Boot · MySQL · Docker
          </dd>
        </div>
        <div class="grid grid-cols-[8rem_1fr] gap-x-3">
          <dt class="text-ink-400 select-none">writes</dt>
          <dd class="text-ink-900">学习笔记 · 项目复盘 · setup-tips</dd>
        </div>
        <div class="grid grid-cols-[8rem_1fr] gap-x-3">
          <dt class="text-ink-400 select-none">not_writes</dt>
          <dd class="text-ink-900">观点 · 鸡汤 · 行业评论</dd>
        </div>
      </dl>

      <!-- 卡内末尾联系方式，不另起 card -->
      <div class="mt-8 pt-6 border-t border-cloud-200 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
        <a
          href={SITE.github}
          target="_blank"
          rel="noopener noreferrer"
          class="paper-link font-medium inline-flex items-center gap-1 group"
        >
          → GitHub @xyd-dev-code<span class="card-arrow">↗</span>
        </a>
        <a
          href="/rss.xml"
          class="paper-link font-medium inline-flex items-center gap-1 group"
        >
          → RSS 订阅<span class="card-arrow">→</span>
        </a>
        <span class="flex items-center gap-2">
          <span class="text-ink-500 font-mono" aria-label="Email">{email}</span>
          <button
            type="button"
            id="copy-email-btn"
            class="text-xs font-mono px-2 py-0.5 rounded-md border border-cloud-300 text-ink-500 hover:text-sky-700 hover:border-sky-500 transition-[color,border-color] duration-[120ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
            data-email={email}
            aria-label="复制邮箱到剪贴板"
          >
            复制
          </button>
        </span>
      </div>
    </article>
  </section>
</BaseLayout>

<script>
  const btn = document.getElementById('copy-email-btn');
  if (btn) {
    btn.addEventListener('click', async () => {
      const email = btn.getAttribute('data-email');
      if (!email) return;
      try {
        await navigator.clipboard.writeText(email);
        const original = btn.textContent;
        btn.textContent = '已复制';
        setTimeout(() => { btn.textContent = original; }, 1500);
      } catch {
        btn.textContent = '复制失败';
        setTimeout(() => { btn.textContent = '复制'; }, 1500);
      }
    });
  }
</script>