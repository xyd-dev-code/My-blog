---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Comments from '~/components/Comments.astro';
---

<BaseLayout title="留言" description="想说点什么都行 — 提问、建议、闲聊、或者只是路过打个招呼。">
  <section class="mx-auto max-w-3xl px-4 sm:px-6 py-8 sm:py-12">
    <header class="mb-8 sm:mb-12 text-center">
      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-bold text-ink-900">
        留言
      </h1>
      <p class="mt-3 text-sm text-ink-500 font-serif italic max-w-xl mx-auto">
        想说点什么都行 — 提问、建议、闲聊,或者只是路过打个招呼。
      </p>
    </header>

    <div class="paper-card p-6 sm:p-8">
      <Comments slug="guestbook" />
    </div>
  </section>
</BaseLayout>
