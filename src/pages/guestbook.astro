---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Comments from '~/components/Comments.astro';
---

<BaseLayout title="留言板" description="想说点什么都行 — 提问、建议、闲聊,或者只是路过打个招呼。">
  <section class="mx-auto max-w-3xl px-4 sm:px-6 py-8 sm:py-12">
    <!-- Hero: 模仿 jerrygao.cn/guestbook 的 eyebrow + 大标题 + 计数 + 写留言 按钮 -->
    <header class="text-center">
      <span class="inline-block px-3 py-1 rounded-full bg-sky-50 border border-sky-200 text-[11px] tracking-[0.18em] font-mono text-sky-700 uppercase">
        ♥ Guestbook
      </span>
      <h1 class="mt-4 font-display text-4xl sm:text-5xl md:text-6xl font-black text-ink-900 tracking-tight">
        留言板
      </h1>
      <p class="mt-3 text-sm text-ink-500 font-serif italic max-w-xl mx-auto">
        想说点什么都行 — 提问、建议、闲聊,或者只是路过打个招呼。
      </p>
      <p class="mt-2 text-xs text-ink-400">
        共 <span class="font-mono tabular-nums text-sky-600">0</span> 条留言
      </p>
      <a
        href="#write-comment"
        class="mt-6 inline-flex items-center gap-2 px-5 py-2 rounded-full bg-gradient-to-br from-sky-50 to-leaf-50 border border-sky-200 text-sm font-medium text-sky-700 hover:border-sky-400 hover:shadow-paper-md transition-[transform,box-shadow,border-color] duration-[120ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
      >
        <span aria-hidden="true">✎</span>
        写留言
      </a>
    </header>

    <!-- 评论块:复用现有 giscus 组件 -->
    <div id="write-comment" class="mt-10 sm:mt-14 paper-card p-6 sm:p-8 scroll-mt-20">
      <Comments slug="guestbook" />
    </div>
  </section>
</BaseLayout>
