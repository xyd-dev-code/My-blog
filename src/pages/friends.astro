---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { friends } from '~/data/friends';

const selfEntry = friends.find((f) => f.group === 'self');
const others = friends.filter((f) => f.group !== 'self');
---

<BaseLayout title="友情链接" description="结识有趣的灵魂,记录值得一去的地方 — 友链 / Friends">
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-8 sm:py-12">
    <!-- Hero: 模仿 jerrygao.cn/friends 的"eyebrow + 大标题 + 副标题 + 计数" -->
    <header class="text-center">
      <span class="inline-block px-3 py-1 rounded-full bg-sky-50 border border-sky-200 text-[11px] tracking-[0.18em] font-mono text-sky-700 uppercase">
        ♥ Friends &amp; Links
      </span>
      <h1 class="mt-4 font-display text-4xl sm:text-5xl md:text-6xl font-black text-ink-900 tracking-tight">
        友情链接
      </h1>
      <p class="mt-3 text-sm text-ink-500 font-serif italic max-w-xl mx-auto">
        结识有趣的灵魂,记录值得一去的地方。
      </p>
      <p class="mt-2 text-xs text-ink-400">
        共收录 <span class="font-mono tabular-nums text-sky-600">{friends.length}</span> 位
      </p>
    </header>

    <!-- 本站作者卡:jerry 用这种"self-highlight"放在网格之上 -->
    {selfEntry && (
      <a
        href={selfEntry.url}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-8 sm:mt-10 mx-auto block max-w-md paper-card p-4 flex items-start gap-3 bg-gradient-to-br from-sky-50 via-white to-leaf-50 border-sky-200 hover:-translate-y-0.5 hover:shadow-paper-md transition-[transform,box-shadow] duration-[120ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
      >
        {selfEntry.avatar ? (
          <img src={selfEntry.avatar} alt={selfEntry.name}
            class="h-11 w-11 rounded-full object-cover bg-white border border-sky-200 shrink-0"
            onerror="this.onerror=null;this.outerHTML='<div aria-hidden=&quot;true&quot; class=&quot;h-11 w-11 rounded-full bg-gradient-to-br from-sky-400 to-sky-600 text-white shrink-0 flex items-center justify-center text-base font-display font-bold&quot;>X</div>'" />
        ) : (
          <div aria-hidden="true"
            class="h-11 w-11 rounded-full bg-gradient-to-br from-sky-400 to-sky-600 text-white shrink-0 flex items-center justify-center text-base font-display font-bold">
            {selfEntry.name.slice(0, 1)}
          </div>
        )}
        <div class="min-w-0 flex-1">
          <div class="text-[11px] font-mono tracking-widest text-sky-600 uppercase">本站作者</div>
          <div class="mt-1 font-display text-base font-bold text-ink-900 truncate">{selfEntry.name}</div>
          <div class="text-[11px] font-mono text-ink-500 truncate">{selfEntry.url}</div>
          <div class="mt-1 text-xs text-ink-500 leading-relaxed line-clamp-2">{selfEntry.desc}</div>
        </div>
      </a>
    )}

    <!-- 分割线 -->
    {others.length > 0 && (
      <>
        <div class="my-10 sm:my-14 border-t border-dashed border-cloud-300"></div>
        <div class="flex items-center gap-2 text-sm font-display">
          <span aria-hidden="true">♥</span>
          <h2 class="font-bold text-ink-900">好友</h2>
          <span class="text-xs text-ink-400 font-mono">({others.length})</span>
        </div>
        <div class="mt-5 grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {others.map((f, i) => (
            <a
              href={f.url}
              target="_blank"
              rel="noopener noreferrer"
              class="relative paper-card p-4 flex items-start gap-3 hover:-translate-y-0.5 hover:shadow-paper-md transition-[transform,box-shadow] duration-[120ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
            >
              {f.avatar ? (
                <img src={f.avatar} alt={f.name}
                  class="h-11 w-11 rounded object-cover bg-cloud-100 border border-cloud-200 shrink-0"
                  onerror="this.onerror=null;this.outerHTML='<div aria-hidden=&quot;true&quot; class=&quot;h-11 w-11 rounded bg-cloud-100 border border-cloud-200 shrink-0 flex items-center justify-center text-sm font-display font-semibold text-ink-500&quot;>J</div>'" />
              ) : (
                <div aria-hidden="true"
                  class="h-11 w-11 rounded bg-cloud-100 border border-cloud-200 shrink-0 flex items-center justify-center text-sm font-display font-semibold text-ink-500">
                  {f.name.slice(0, 1)}
                </div>
              )}
              <div class="min-w-0 flex-1">
                <div class="font-display text-base font-bold text-ink-900 truncate">{f.name}</div>
                <div class="text-[11px] font-mono text-ink-500 truncate">{new URL(f.url).hostname}</div>
                <div class="mt-1 text-xs text-ink-500 leading-relaxed line-clamp-3">{f.desc}</div>
              </div>
              <!-- 右下角序号 -->
              <span class="absolute bottom-2 right-2 text-[10px] font-mono tabular-nums text-cloud-300">
                {String(i + 1).padStart(2, '0')}
              </span>
            </a>
          ))}
        </div>
      </>
    )}

    {others.length === 0 && !selfEntry && (
      <div class="paper-card p-12 mt-10 text-center">
        <p class="text-ink-500">友链列表是空的。在 <code class="px-1 py-0.5 rounded bg-cloud-100 font-mono text-xs">src/data/friends.ts</code> 里加几个吧。</p>
      </div>
    )}

    <!-- 申请友链:jerry 在末尾的做法 —— 信箱图标 + 标题 + 4 点条件 + 主按钮 -->
    <div class="mt-12 sm:mt-16 paper-card p-6 sm:p-10 text-center bg-gradient-to-br from-sky-50/40 via-white to-leaf-50/30 border-dashed">
      <div aria-hidden="true"
        class="mx-auto mb-4 h-12 w-12 rounded-2xl bg-gradient-to-br from-sky-100 to-leaf-100 border border-sky-200 flex items-center justify-center text-2xl text-sky-600">
        ✉
      </div>
      <h2 class="font-display text-2xl sm:text-3xl font-black text-ink-900">申请友链</h2>
      <p class="mt-2 text-sm text-ink-500 font-serif italic">
        如果你有优质的个人网站,欢迎互换友链。请确认满足以下条件:
      </p>

      <ul class="mt-6 max-w-2xl mx-auto grid gap-3 sm:grid-cols-2 text-left">
        {[
          '个人博客或独立网站,非商业推广',
          '站点内容积极健康,原创为主',
          '网站可正常访问,稳定运营中',
          '先将本站加入你的友链 😉',
        ].map((rule) => (
          <li class="flex items-start gap-2 px-4 py-3 rounded-xl bg-white/70 border border-cloud-200 text-sm text-ink-700">
            <span aria-hidden="true" class="mt-0.5 inline-flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-leaf-100 text-leaf-600 text-xs font-bold">✓</span>
            <span>{rule}</span>
          </li>
        ))}
      </ul>

      <a
        href="mailto:x2597486661@gmail.com?subject=友链申请&body=你好,我想申请友链:%0A%0A站点名称:%0A站点链接:%0A站点描述:"
        class="mt-7 inline-flex items-center gap-2 px-6 py-3 rounded-full paper-card border-cloud-200 bg-white text-sm font-medium text-ink-700 hover:-translate-y-0.5 hover:shadow-paper-md transition-[transform,box-shadow] duration-[120ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
      >
        填写申请信息
        <span aria-hidden="true">↓</span>
      </a>
    </div>
  </section>
</BaseLayout>
