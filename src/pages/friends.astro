---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { friends } from '~/data/friends';
---

<BaseLayout title="友链" description="技术路上互相串门的同行 — 友链 / Friends">
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-8 sm:py-12">
    <header class="mb-8 sm:mb-12 text-center">
      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-bold text-ink-900">
        友链
      </h1>
      <p class="mt-3 text-sm text-ink-500 font-serif italic max-w-xl mx-auto">
        收藏夹里的常客 — 写得认真、写得有趣、写得让人想点进去的人。
      </p>
      <p class="mt-2 text-xs text-ink-400">
        <span class="text-leaf-500">●</span> {friends.length} friend{friends.length === 1 ? '' : 's'} in circle
      </p>
    </header>

    {friends.length > 0 ? (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {friends.map((f) => (
          <a
            href={f.url}
            target="_blank"
            rel="noopener noreferrer"
            class="paper-card p-5 flex items-start gap-4 transition-[transform,box-shadow] duration-[120ms] ease-[cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-0.5 hover:shadow-paper-md"
          >
            {f.avatar ? (
              <img
                src={f.avatar}
                alt={f.name}
                class="h-12 w-12 rounded-full object-cover bg-cloud-100 border border-cloud-300 shrink-0"
                onerror="this.onerror=null;this.style.display='none';"
              />
            ) : (
              <div
                aria-hidden="true"
                class="h-12 w-12 rounded-full bg-cloud-100 border border-cloud-300 shrink-0 flex items-center justify-center text-sm font-display font-semibold text-ink-500"
              >
                {f.name.slice(0, 1)}
              </div>
            )}
            <div class="min-w-0">
              <div class="font-display text-base font-semibold text-ink-900 truncate">
                {f.name}
              </div>
              <div class="mt-1 text-xs text-ink-500 leading-relaxed line-clamp-2">
                {f.desc}
              </div>
              <div class="mt-2 text-[11px] font-mono text-sky-600 truncate">
                {new URL(f.url).hostname}
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="paper-card p-12 text-center">
        <p class="text-ink-500">
          友链列表是空的。在 <code class="px-1 py-0.5 rounded bg-cloud-100 font-mono text-xs">src/data/friends.ts</code> 里加几个吧。
        </p>
      </div>
    )}

    <p class="mt-10 text-center text-xs text-ink-400 font-serif italic">
      想互相串门?去 <a href="/guestbook" class="paper-link">留言页</a> 留个链接,我看到会回访。
    </p>
  </section>
</BaseLayout>
