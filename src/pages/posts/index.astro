---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDateShort } from '~/utils/date';
import { STOP_TAGS, filterTags, SITE } from '~/consts';

// 构建时始终按 desc 排序（最新优先）。切换到 asc 由客户端脚本处理。
const all = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const posts = all;

// 侧栏即时搜索索引 + 跨页排序所需的全量元数据
const searchIndex = all.map((p) => ({
  t: p.data.title,
  d: p.data.description,
  tags: p.data.tags ?? [],
  url: `/posts/${p.id}`,
  pubDate: p.data.pubDate.toISOString(),
  cover: p.data.cover ?? '',
}));
// 客户端按 dir 排序后再分页的元数据（不带 description，避免 JSON 过大）
const allPostsMeta = all.map((p) => ({
  id: p.id,
  pubDate: p.data.pubDate.toISOString(),
}));
---
<BaseLayout title="Posts" description="所有文章 — 学习笔记、项目复盘、工具流。">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 py-6 lg:py-10">
    <section class="flex flex-col">
      <header class="mb-5 text-center px-2">
        <h1 class="font-display text-2xl sm:text-3xl md:text-4xl font-bold text-ink-900">
          所有文章
        </h1>
        <p class="mt-2 text-sm text-ink-500 font-serif italic max-w-xl mx-auto">
          学习笔记、项目复盘、工具流。点进任意卡片看完整内容。
        </p>
        <p class="mt-1.5 text-xs text-ink-400">
          共 <span class="font-mono tabular-nums text-sky-600">{all.length}</span> 篇,按发布顺序倒序排列
        </p>
        <!-- 排序切换(客户端重排) -->
        <div
          class="mt-3 inline-flex items-center gap-1 p-0.5 rounded-full border border-cloud-300 bg-white/70 text-xs"
          data-sort-toggle
          data-default="desc"
        >
          <button
            type="button"
            data-sort="desc"
            class:list={[
              'px-3 py-1 rounded-full transition-colors',
              'bg-sky-500 text-white shadow-sm',
            ]}
            title="按发布日期倒序(最新在前)"
          >
            ↓ 最新优先
          </button>
          <button
            type="button"
            data-sort="asc"
            class:list={[
              'px-3 py-1 rounded-full transition-colors',
              'text-ink-500 hover:text-sky-700',
            ]}
            title="按发布日期顺序(最早在前)"
          >
            ↑ 开篇优先
          </button>
        </div>
        <!-- 站内搜索:标题/描述/标签即时过滤 -->
        <div class="mt-4 max-w-md mx-auto">
          <div class="relative">
            <input
              id="sidebar-search"
              type="text"
              placeholder="输入标题 / 标签..."
              class="w-full pl-9 pr-3 py-2 text-sm rounded-md border border-cloud-300 bg-white/70 placeholder:text-ink-400 focus:outline-none focus:border-sky-400 focus:ring-1 focus:ring-sky-200 transition-colors"
            />
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-ink-400 pointer-events-none">
              <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
            </svg>
          </div>
          <div id="sidebar-search-results" class="mt-2 max-h-60 overflow-y-auto space-y-1.5 text-left hidden"></div>
          <script type="application/json" id="search-index" set:html={JSON.stringify(searchIndex)} />
        </div>
      </header>

        {posts.length === 0 ? (
          <p class="text-ink-500 text-center py-12">暂无文章。</p>
        ) : (
          <ul class="space-y-4" data-posts-list>
            {posts.map((post) => (
              <li data-pubdate={post.data.pubDate.toISOString()}>
                <a
                  href={`/posts/${post.id}`}
                  class="group paper-card flex flex-col block overflow-hidden transition-[transform,box-shadow] duration-[220ms] ease-[cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-[2px] hover:shadow-md relative"
                >
                  <div class="flex-1 flex flex-col sm:flex-row">
                    <div class="w-28 h-28 shrink-0 overflow-hidden bg-cloud-200 rounded">
                      {post.data.cover && (
                        <img
                          src={post.data.cover}
                          alt={post.data.title}
                          loading="eager"
                          decoding="async"
                          referrerpolicy="no-referrer"
                          class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
                        />
                      )}
                    </div>
                    <div class="flex-1 min-w-0 p-4 sm:p-5">
                      <div class="flex items-baseline justify-between gap-3">
                        <h2 class="font-display text-base sm:text-lg font-semibold text-ink-900 group-hover:text-sky-700 transition-[color] duration-[120ms] leading-snug line-clamp-2">
                          {post.data.title}
                        </h2>
                        <time
                          datetime={post.data.pubDate.toISOString()}
                          class="text-xs text-ink-400 font-mono tabular-nums shrink-0 hidden sm:block"
                        >
                          {formatDateShort(post.data.pubDate)}
                        </time>
                      </div>
                      <p class="mt-1.5 text-sm text-ink-500 line-clamp-3 leading-relaxed">
                        {post.data.description}
                      </p>
                      {post.data.tags && post.data.tags.length > 0 && (
                        <div class="mt-3 flex flex-wrap gap-1.5">
                          {filterTags(post.data.tags ?? []).slice(0, 4).map((t, i) => (
                            <span
                              class:list={[
                                'tag-chip',
                                i % 3 === 1 ? 'tag-chip-warm' : i % 3 === 2 ? 'tag-chip-leaf' : '',
                              ]}
                            >
                              #{t}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )}
        <script type="application/json" id="all-posts-data" set:html={JSON.stringify(allPostsMeta)} />
      </section>
    </div>
  </div>
</BaseLayout>

<script>
  // 文章排序切换（不分页：升序/降序整页重排）
  const toggle = document.querySelector<HTMLElement>('[data-sort-toggle]');
  const list = document.querySelector<HTMLElement>('[data-posts-list]');
  const metaEl = document.getElementById('all-posts-data');
  const searchEl = document.getElementById('search-index');

  if (toggle && list && metaEl && searchEl) {
    const allMeta: {id:string; pubDate:string}[] = JSON.parse(metaEl.textContent || '[]');
    const searchData: {t:string;d:string;tags:string[];url:string;pubDate:string;cover:string}[] = JSON.parse(searchEl.textContent || '[]');
    const metaById = new Map(allMeta.map((m) => [m.id, m]));
    const detailById = new Map(searchData.map((s) => [s.url.replace('/posts/',''), s]));

    const esc = (s: string) => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    const fmtDate = (iso: string) => {
      const d = new Date(iso);
      const y = d.getFullYear();
      const m = String(d.getMonth() + 1).padStart(2, '0');
      const day = String(d.getDate()).padStart(2, '0');
      return `${y}-${m}-${day}`;
    };
    const renderCard = (id: string) => {
      const detail = detailById.get(id);
      const meta = metaById.get(id);
      if (!detail || !meta) return '';
      const cover = detail.cover ? `<img src="${esc(detail.cover)}" alt="${esc(detail.t)}" loading="eager" decoding="async" referrerpolicy="no-referrer" class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]" />` : '';
      const tagsHtml = (detail.tags || []).slice(0, 4).map((t, i) => `<span class="tag-chip${i%3===1?' tag-chip-warm':''}${i%3===2?' tag-chip-leaf':''}">#${esc(t)}</span>`).join('');
      return `<li data-pubdate="${meta.pubDate}" data-post-id="${esc(id)}"><a href="/posts/${esc(id)}" class="group paper-card flex flex-col block overflow-hidden min-h-[12rem] transition-[transform,box-shadow] duration-[220ms] ease-[cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-[2px] hover:shadow-md relative"><div class="flex-1 flex flex-col sm:flex-row"><div class="sm:w-40 shrink-0 self-stretch overflow-hidden bg-cloud-200">${cover}</div><div class="flex-1 min-w-0 p-4 sm:p-5"><div class="flex items-baseline justify-between gap-3"><h2 class="font-display text-base sm:text-lg font-semibold text-ink-900 group-hover:text-sky-700 transition-[color] duration-[120ms] leading-snug line-clamp-2">${esc(detail.t)}</h2><time datetime="${meta.pubDate}" class="text-xs text-ink-400 font-mono tabular-nums shrink-0 hidden sm:block">${fmtDate(meta.pubDate)}</time></div><p class="mt-1.5 text-sm text-ink-500 line-clamp-3 leading-relaxed">${esc(detail.d)}</p>${tagsHtml ? `<div class="mt-3 flex flex-wrap gap-1.5">${tagsHtml}</div>` : ''}</div></div></a></li>`;
    };

    let currentSort: 'desc' | 'asc' = 'desc';

    const renderList = () => {
      const sorted = [...allMeta].sort((a, b) => currentSort === 'asc'
        ? new Date(a.pubDate).getTime() - new Date(b.pubDate).getTime()
        : new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime());
      list.innerHTML = sorted.map((p) => renderCard(p.id)).join('');
    };

    const updateButtons = () => {
      toggle.querySelectorAll<HTMLButtonElement>('[data-sort]').forEach((b) => {
        const active = b.dataset.sort === currentSort;
        b.classList.toggle('bg-sky-500', active);
        b.classList.toggle('text-white', active);
        b.classList.toggle('shadow-sm', active);
        b.classList.toggle('text-ink-500', !active);
        b.classList.toggle('hover:text-sky-700', !active);
      });
    };

    const applySort = (dir: 'desc' | 'asc') => {
      currentSort = dir;
      updateButtons();
      renderList();
      try { localStorage.setItem('posts-sort', dir); } catch {}
    };

    // 读取上次选择（默认 desc）
    try {
      const v = localStorage.getItem('posts-sort');
      if (v === 'asc' || v === 'desc') currentSort = v;
    } catch {}
    if (currentSort === 'asc') renderList();
    updateButtons();
    toggle.querySelectorAll<HTMLButtonElement>('[data-sort]').forEach((b) => {
      b.addEventListener('click', () => applySort(b.dataset.sort as 'desc' | 'asc'));
    });
  }

  // 侧栏即时搜索
  const indexEl = document.getElementById('search-index');
  const index: {t:string;d:string;tags:string[];url:string}[] = indexEl ? JSON.parse(indexEl.textContent!) : [];
  const input = document.getElementById('sidebar-search') as HTMLInputElement | null;
  const results = document.getElementById('sidebar-search-results');

  function doSearch() {
    if (!input || !results) return;
    const q = input.value.trim().toLowerCase();
    if (!q) { results.classList.add('hidden'); results.innerHTML = ''; return; }
    const matched = index.filter(p =>
      p.t.toLowerCase().includes(q) ||
      p.d.toLowerCase().includes(q) ||
      p.tags.some(t => t.toLowerCase().includes(q))
    ).slice(0, 8);
    if (!matched.length) {
      results.innerHTML = '<p class="text-xs text-ink-400 py-2">无匹配结果</p>';
    } else {
      results.innerHTML = matched.map(p =>
        `<a href="${p.url}" class="block group py-1.5 px-2 -mx-2 rounded hover:bg-sky-50 transition-colors">` +
          `<p class="text-sm text-ink-800 group-hover:text-sky-700 leading-snug line-clamp-2">${esc(p.t)}</p>` +
          `<p class="text-[11px] text-ink-400 mt-0.5">${p.tags.slice(0,3).map(t=>'#'+esc(t)).join(' ')}</p>` +
        `</a>`
      ).join('');
    }
    results.classList.remove('hidden');
  }
  function esc(s: string) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  input?.addEventListener('input', doSearch);

</script>

<style>
  /* 移动/平板下隐藏右栏的搜索/标签云卡片的最末装饰，避免过满 */
  @media (max-width: 1023px) {
    .paper-card { border-radius: 1rem; }
  }
</style>
</BaseLayout>
