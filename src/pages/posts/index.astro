---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDateShort } from '~/utils/date';
import { POSTS_PER_PAGE } from '~/consts';

const all = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const page = Number(Astro.url.searchParams.get('page') ?? '1');
const totalPages = Math.max(1, Math.ceil(all.length / POSTS_PER_PAGE));
const currentPage = Math.min(Math.max(1, page), totalPages);
const posts = all.slice((currentPage - 1) * POSTS_PER_PAGE, currentPage * POSTS_PER_PAGE);
---
<BaseLayout title="Posts" description="所有文章 — 学习笔记、项目复盘、工具流。">
  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-12">
    <header class="mb-12 text-center">
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-ink-900">
        所有文章
      </h1>
      <p class="mt-3 text-sm text-ink-500 font-serif italic">
        all posts · 共 {all.length} 篇 · 第 {currentPage} / {totalPages} 页
      </p>
    </header>

    {posts.length === 0 ? (
      <p class="text-ink-500 text-center py-12">暂无文章。</p>
    ) : (
      <ul class="space-y-4">
        {posts.map((post) => (
          <li>
            <a
              href={`/posts/${post.id}`}
              class="paper-card block p-6 transition-transform hover:-translate-y-0.5"
            >
              <div class="flex items-baseline justify-between gap-4 mb-2">
                <h2 class="font-display text-xl font-semibold text-ink-900 hover:text-sky-700 transition-colors">
                  {post.data.title}
                </h2>
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="text-xs text-ink-400 shrink-0"
                >
                  {formatDateShort(post.data.pubDate)}
                </time>
              </div>
              <p class="text-ink-500 line-clamp-2 leading-relaxed">{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-1.5">
                  {post.data.tags.slice(0, 4).map((t, i) => (
                    <span
                      class:list={[
                        'tag-chip',
                        i % 3 === 1 ? 'tag-chip-warm' : i % 3 === 2 ? 'tag-chip-leaf' : '',
                      ]}
                    >
                      #{t}
                    </span>
                  ))}
                </div>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}

    {totalPages > 1 && (
      <nav class="mt-12 flex items-center justify-center gap-2 text-sm">
        {currentPage > 1 && (
          <a href={`/posts?page=${currentPage - 1}`} class="tag-chip">← 上一页</a>
        )}
        <span class="text-ink-500 px-3">
          {currentPage} / {totalPages}
        </span>
        {currentPage < totalPages && (
          <a href={`/posts?page=${currentPage + 1}`} class="tag-chip">下一页 →</a>
        )}
      </nav>
    )}
  </section>
</BaseLayout>
