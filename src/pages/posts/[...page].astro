---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDateShort } from '~/utils/date';
import { POSTS_PER_PAGE, STOP_TAGS, filterTags } from '~/consts';

export async function getStaticPaths() {
  const all = (await getCollection('posts', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
  const totalPages = Math.max(1, Math.ceil(all.length / POSTS_PER_PAGE));
  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: i === 0 ? undefined : String(i + 1) },
  }));
}

const all = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const totalPages = Math.max(1, Math.ceil(all.length / POSTS_PER_PAGE));
const rawPage = Astro.params.page;
const currentPage = rawPage === undefined ? 1 : Math.min(Math.max(1, Number(rawPage)), totalPages);
const posts = all.slice((currentPage - 1) * POSTS_PER_PAGE, currentPage * POSTS_PER_PAGE);

const pageHref = (n: number) => (n === 1 ? '/posts' : `/posts/${n}`);

// 生成分页页码数组
function getPageNumbers(current: number, total: number): (number | '...')[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
  const pages: (number | '...')[] = [];
  pages.push(1);
  if (current > 3) pages.push('...');
  const start = Math.max(2, current - 1);
  const end = Math.min(total - 1, current + 1);
  for (let i = start; i <= end; i++) pages.push(i);
  if (current < total - 2) pages.push('...');
  pages.push(total);
  return pages;
}

// 侧栏即时搜索索引
const searchIndex = all.map((p) => ({
  t: p.data.title,
  d: p.data.description,
  tags: p.data.tags ?? [],
  url: `/posts/${p.id}`,
}));

// 侧栏：最新 / 热门（无阅读量，取最近 4 篇与中段 4 篇作为"热门"）
const latest = all.slice(0, 4);
const hot = all.slice(4, 8);

// 标签云：仅保留技术相关 tag
const tagCounts = new Map<string, number>();
all.forEach((p) => (p.data.tags ?? []).forEach((t) => {
  if (STOP_TAGS.has(t)) return;
  tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
}));
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 30);

// 标签云：固定技术关键词，按权重分级 + 分类配色
// 权重: 3=高(≈24px) 2=中(≈18px) 1=低(≈14px)
// 分类: framework=橙(核心框架) blue=蓝(编程/语言) purple=紫(理论/算法) gray=灰(基础工具)
const TAG_CLOUD = [
  { name: 'MySQL',       w: 3, cat: 'framework' },
  { name: 'SpringBoot',  w: 3, cat: 'framework' },
  { name: 'Redis',       w: 3, cat: 'framework' },
  { name: 'Vue',         w: 3, cat: 'blue' },
  { name: 'Java',        w: 3, cat: 'blue' },
  { name: 'C++',         w: 2, cat: 'blue' },
  { name: 'Docker',      w: 2, cat: 'framework' },
  { name: 'Linux',       w: 2, cat: 'gray' },
  { name: 'MyBatis',     w: 2, cat: 'framework' },
  { name: 'JDBC',        w: 2, cat: 'framework' },
  { name: 'Maven',       w: 2, cat: 'gray' },
  { name: 'JWT',         w: 2, cat: 'framework' },
  { name: 'AOP',         w: 2, cat: 'framework' },
  { name: '数据结构',     w: 2, cat: 'purple' },
  { name: 'Web',         w: 2, cat: 'blue' },
  { name: 'Axios',       w: 1, cat: 'blue' },
  { name: 'JUnit',       w: 1, cat: 'framework' },
  { name: '全栈',        w: 1, cat: 'purple' },
  { name: '重构',        w: 1, cat: 'purple' },
  { name: 'Nginx',       w: 2, cat: 'gray' },
  { name: 'Git',         w: 2, cat: 'gray' },
  { name: 'Spring',      w: 2, cat: 'framework' },
  { name: 'SQL',         w: 2, cat: 'framework' },
  { name: 'TypeScript',  w: 1, cat: 'blue' },
  { name: '设计模式',     w: 2, cat: 'purple' },
  { name: '算法',        w: 2, cat: 'purple' },
  { name: '网络',        w: 1, cat: 'purple' },
  { name: '操作系统',     w: 1, cat: 'purple' },
];

// 分类 → 调色板（每个标签按 cat 选色，同 cat 内用 name hash 微调色相偏移）
const CAT_PALETTES: Record<string, string[]> = {
  framework: ['#ea580c','#dc2626','#d97706','#c2410c','#b91c1c'],  // 橙红系
  blue:      ['#0284c7','#2563eb','#0891b2','#1d4ed8','#0369a1'],  // 蓝系
  purple:    ['#9333ea','#7c3aed','#a855f7','#6d28d9','#8b5cf6'],  // 紫系
  gray:      ['#475569','#64748b','#57534e','#6b7280','#78716c'],   // 灰系
};
const hashStr = (s: string) => { let h = 0; for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) | 0; return h; };

// build-time 生成均匀分布位置：垂直方向按索引均匀分布 + hash 随机偏移
const sorted = [...TAG_CLOUD].sort((a, b) => b.w - a.w);
const tagCloudStyled = sorted.map((t, i) => {
  const h = hashStr(t.name);
  const ah = Math.abs(h);
  const palette = CAT_PALETTES[t.cat] ?? CAT_PALETTES.gray;
  const color = palette[ah % palette.length];
  const sizeRem = t.w === 3 ? 1.5 : t.w === 2 ? 1.125 : 0.875;
  const rotate = (ah % 9) - 4;
  const opacity = t.w === 3 ? 1 : t.w === 2 ? 0.88 : 0.72;
  const leftPct = 2 + ((ah * 2654435761) >>> 0) % 71; // 2~72%
  // 垂直方向均匀分布：每个标签占据大致等高的区间，加上 hash 随机偏移
  const baseTop = (i / sorted.length) * 75 + 5; // 5~80
  const topPct = baseTop + (ah % 15); // 5~95
  return { ...t, color, sizeRem, rotate, opacity, leftPct, topPct };
});

// 统计：累计字数 / 最早发布 / 平均篇长
const totalWords = all.reduce((sum, p) => sum + (p.body?.split(/\s+/).length ?? 0), 0);
const earliest = all[all.length - 1]?.data.pubDate;
---
<BaseLayout title="Posts" description="所有文章 — 学习笔记、项目复盘、工具流。">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6 lg:py-8">
    <div class="grid grid-cols-1 lg:grid-cols-[16rem_minmax(0,1fr)_16rem] lg:grid-rows-[minmax(0,1fr)_auto] gap-6 lg:gap-8 items-stretch">

      <!-- 左 sidebar -->
      <aside class="hidden lg:flex flex-col space-y-5 lg:[padding-top:var(--posts-header-h,0px)]" data-sidebar>
        <div class="paper-card p-5">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-sky-300 to-sky-500 ring-2 ring-white shadow-sm shrink-0"></div>
            <div class="min-w-0">
              <p class="font-display font-semibold text-ink-900 leading-tight">XiaoyouDong</p>
              <p class="text-xs text-ink-500 mt-0.5">学习笔记 · 项目复盘 · 工具流</p>
            </div>
          </div>
          <div class="mt-4 grid grid-cols-3 gap-2 text-center">
            <div>
              <p class="font-display text-lg font-semibold text-ink-900 tabular-nums">{all.length}</p>
              <p class="text-[11px] text-ink-500">文章</p>
            </div>
            <div>
              <p class="font-display text-lg font-semibold text-ink-900 tabular-nums">{tags.length}</p>
              <p class="text-[11px] text-ink-500">标签</p>
            </div>
            <div>
              <p class="font-display text-lg font-semibold text-ink-900 tabular-nums">{totalPages}</p>
              <p class="text-[11px] text-ink-500">页</p>
            </div>
          </div>
          <p class="mt-4 text-xs text-ink-400 font-serif italic">慢慢写，持续复盘。</p>
        </div>

        <div class="paper-card p-5">
          <p class="flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-ink-400 mb-3">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5"><path d="M12 2v6m0 12v2m10-10h-2M4 12H2m15.5-7.5-1.4 1.4M7.9 16.1l-1.4 1.4m0-11 1.4 1.4m8.2 8.2 1.4 1.4"/><circle cx="12" cy="12" r="4"/></svg>
            最新文章
          </p>
          <ul class="space-y-4">
            {latest.map((p) => (
              <li>
                <a href={`/posts/${p.id}`} class="block group">
                  <p class="text-sm text-ink-800 group-hover:text-sky-700 transition-[color] leading-snug line-clamp-2">
                    {p.data.title}
                  </p>
                  <p class="mt-0.5 text-[11px] text-ink-400 font-mono tabular-nums">
                    {formatDateShort(p.data.pubDate)}
                  </p>
                </a>
              </li>
            ))}
            </ul>
        </div>

        <div class="flex-1 min-h-0"></div>

        <div class="paper-card p-5">
          <p class="flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-ink-400 mb-3">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5"><path d="M12 2 9 9l-7 1 5 5-1 7 6-3 6 3-1-7 5-5-7-1z"/></svg>
            热门文章
          </p>
          <ul class="space-y-4">
            {hot.map((p, i) => (
              <li>
                <a href={`/posts/${p.id}`} class="flex items-baseline gap-2 group">
                  <span class="font-display text-sm font-semibold text-sky-700 tabular-nums shrink-0">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <p class="text-sm text-ink-800 group-hover:text-sky-700 transition-[color] leading-snug line-clamp-2">
                    {p.data.title}
                  </p>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </aside>

      <!-- 主区 -->
      <section class="flex flex-col">
        <header class="mb-3 text-center">
          <h1 class="font-display text-3xl sm:text-4xl font-bold text-ink-900">
            所有文章
          </h1>
          <p class="mt-2 text-sm text-ink-500 font-serif italic max-w-xl mx-auto">
            学习笔记、项目复盘、工具流。点进任意卡片看完整内容。
          </p>
          <p class="mt-1.5 text-xs text-ink-400">
            <span class="text-leaf-500">●</span> {all.length} article{all.length === 1 ? '' : 's'} found
            <span class="mx-1.5 text-ink-300">·</span>
            <span class="font-mono tabular-nums">{currentPage} / {totalPages}</span>
          </p>
        </header>

        {posts.length === 0 ? (
          <p class="text-ink-500 text-center py-12">暂无文章。</p>
        ) : (
          <ul class="space-y-4">
            {posts.map((post) => (
              <li>
                <a
                  href={`/posts/${post.id}`}
                  class="group paper-card flex flex-col block overflow-hidden min-h-[12rem] transition-[transform,box-shadow] duration-[220ms] ease-[cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-[2px] hover:shadow-md"
                >
                  <div class="flex-1 flex flex-col sm:flex-row">
                    <div class="sm:w-40 shrink-0 self-stretch overflow-hidden bg-cloud-200">
                      {post.data.cover && (
                        <img
                          src={post.data.cover}
                          alt={post.data.title}
                          loading="eager"
                          decoding="async"
                          referrerpolicy="no-referrer"
                          class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
                        />
                      )}
                    </div>
                    <div class="flex-1 min-w-0 p-4 sm:p-5">
                      <div class="flex items-baseline justify-between gap-3">
                        <h2 class="font-display text-base sm:text-lg font-semibold text-ink-900 group-hover:text-sky-700 transition-[color] duration-[120ms] leading-snug line-clamp-2">
                          {post.data.title}
                        </h2>
                        <time
                          datetime={post.data.pubDate.toISOString()}
                          class="text-xs text-ink-400 font-mono tabular-nums shrink-0 hidden sm:block"
                        >
                          {formatDateShort(post.data.pubDate)}
                        </time>
                      </div>
                      <p class="mt-1.5 text-sm text-ink-500 line-clamp-3 leading-relaxed">
                        {post.data.description}
                      </p>
                      {post.data.tags && post.data.tags.length > 0 && (
                        <div class="mt-3 flex flex-wrap gap-1.5">
                          {filterTags(post.data.tags ?? []).slice(0, 4).map((t, i) => (
                            <span
                              class:list={[
                                'tag-chip',
                                i % 3 === 1 ? 'tag-chip-warm' : i % 3 === 2 ? 'tag-chip-leaf' : '',
                              ]}
                            >
                              #{t}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>

      <!-- 右 sidebar -->
      <aside class="hidden lg:flex flex-col space-y-5 lg:[padding-top:var(--posts-header-h,0px)]" data-sidebar>
        <div class="paper-card p-5">
          <p class="flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-ink-400 mb-3">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5">
              <circle cx="11" cy="11" r="7"/>
              <path d="m20 20-3.5-3.5"/>
            </svg>
            站内搜索
          </p>
          <div class="relative">
            <input
              id="sidebar-search"
              type="text"
              placeholder="输入标题 / 标签..."
              class="w-full pl-8 pr-3 py-2 text-sm rounded-md border border-cloud-300 bg-white/70 placeholder:text-ink-400 focus:outline-none focus:border-sky-400 focus:ring-1 focus:ring-sky-200 transition-colors"
            />
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-ink-400 pointer-events-none">
              <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
            </svg>
          </div>
          <div id="sidebar-search-results" class="mt-2 max-h-60 overflow-y-auto space-y-1.5 hidden"></div>
          <script type="application/json" id="search-index" set:html={JSON.stringify(searchIndex)} />
        </div>

        <div class="paper-card p-5 relative overflow-hidden" style="min-height:480px">
          <p class="font-mono text-xs uppercase tracking-widest text-ink-400 mb-2 relative z-10">技术关键词</p>
          <div class="relative w-full" style="height:430px" data-tag-cloud-container>
            {tagCloudStyled.map((t, i) => (
              <a
                href={`/tags/${encodeURIComponent(t.name)}`}
                class="absolute font-display font-bold whitespace-nowrap no-underline hover:scale-110 transition-transform duration-200 select-none"
                title={t.name}
                data-tc
                data-w={t.w}
                data-x={t.leftPct}
                data-y={t.topPct}
                style={`
                  color:${t.color};
                  font-size:${t.sizeRem}rem;
                  opacity:${t.opacity};
                  left:${t.leftPct}%;
                  top:${t.topPct}%;
                  transform:rotate(${t.rotate}deg);
                  text-shadow:0 1px 3px rgba(0,0,0,0.06);
                  z-index:${t.w};
                `}
              >
                {t.name}
              </a>
            ))}
          </div>
        </div>

        <div class="paper-card p-5">
          <p class="font-mono text-xs uppercase tracking-widest text-ink-400 mb-3">订阅</p>
          <a href="/rss.xml" class="flex items-center gap-2 text-sm text-ink-600 hover:text-sky-700 transition-colors">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
              <path d="M4 11a9 9 0 0 1 9 9"/>
              <path d="M4 4a16 16 0 0 1 16 16"/>
              <circle cx="5" cy="19" r="1.5" fill="currentColor"/>
            </svg>
            RSS 订阅
          </a>
        </div>
      </aside>

      {totalPages > 1 && (
        <nav class="lg:col-start-2 lg:row-start-2 flex items-center justify-center gap-1.5 text-sm py-2">
          <!-- 左箭头 -->
          {currentPage > 1 ? (
            <a href={pageHref(currentPage - 1)} title="上一页"
               class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-cloud-300 text-ink-600 hover:border-sky-400 hover:text-sky-700 transition-colors">←</a>
          ) : (
            <span class="w-8 h-8 flex items-center justify-center rounded-lg text-ink-300 cursor-not-allowed">←</span>
          )}

          <!-- 页码 -->
          {getPageNumbers(currentPage, totalPages).map((p) =>
            p === '...' ? (
              <span class="w-8 h-8 flex items-center justify-center text-ink-400">…</span>
            ) : p === currentPage ? (
              <span class="w-8 h-8 flex items-center justify-center rounded-lg bg-sky-500 text-white font-medium">{p}</span>
            ) : (
              <a href={pageHref(p)} class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-cloud-300 text-ink-600 hover:border-sky-400 hover:text-sky-700 transition-colors">{p}</a>
            )
          )}

          <!-- 右箭头 -->
          {currentPage < totalPages ? (
            <a href={pageHref(currentPage + 1)} title="下一页"
               class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-cloud-300 text-ink-600 hover:border-sky-400 hover:text-sky-700 transition-colors">→</a>
          ) : (
            <span class="w-8 h-8 flex items-center justify-center rounded-lg text-ink-300 cursor-not-allowed">→</span>
          )}
        </nav>
      )}

    </div>
  </div>
</BaseLayout>

<script>
  // 侧栏即时搜索
  const indexEl = document.getElementById('search-index');
  const index: {t:string;d:string;tags:string[];url:string}[] = indexEl ? JSON.parse(indexEl.textContent!) : [];
  const input = document.getElementById('sidebar-search') as HTMLInputElement | null;
  const results = document.getElementById('sidebar-search-results');

  function doSearch() {
    if (!input || !results) return;
    const q = input.value.trim().toLowerCase();
    if (!q) { results.classList.add('hidden'); results.innerHTML = ''; return; }
    const matched = index.filter(p =>
      p.t.toLowerCase().includes(q) ||
      p.d.toLowerCase().includes(q) ||
      p.tags.some(t => t.toLowerCase().includes(q))
    ).slice(0, 8);
    if (!matched.length) {
      results.innerHTML = '<p class="text-xs text-ink-400 py-2">无匹配结果</p>';
    } else {
      results.innerHTML = matched.map(p =>
        `<a href="${p.url}" class="block group py-1.5 px-2 -mx-2 rounded hover:bg-sky-50 transition-colors">` +
          `<p class="text-sm text-ink-800 group-hover:text-sky-700 leading-snug line-clamp-2">${esc(p.t)}</p>` +
          `<p class="text-[11px] text-ink-400 mt-0.5">${p.tags.slice(0,3).map(t=>'#'+esc(t)).join(' ')}</p>` +
        `</a>`
      ).join('');
    }
    results.classList.remove('hidden');
  }
  function esc(s: string) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  input?.addEventListener('input', doSearch);

  // 把 main header 的高度写入 CSS 变量，让左右 sidebar 顶部和首张卡对齐
  const syncSidebarOffset = () => {
    const header = document.querySelector('section > header');
    if (!header) return;
    const firstCard = document.querySelector('section > ul > li');
    if (!firstCard) return;
    const sidebar = document.querySelector('[data-sidebar]');
    if (!sidebar) return;
    const d = firstCard.getBoundingClientRect().top - sidebar.getBoundingClientRect().top;
    document.documentElement.style.setProperty('--posts-header-h', Math.max(0, Math.round(d)) + 'px');
  };
  syncSidebarOffset();
  window.addEventListener('resize', syncSidebarOffset);
  if (document.fonts?.ready) document.fonts.ready.then(syncSidebarOffset);

  // 技术关键词：用真实 DOM 尺寸解决重叠
  function resolveTagCloud() {
    const container = document.querySelector<HTMLElement>('[data-tag-cloud-container]');
    if (!container) return;
    const CW = container.offsetWidth, CH = container.offsetHeight;
    const GAP = 4;
    const tags = Array.from(container.querySelectorAll<HTMLElement>('[data-tc]'));
    if (!tags.length) return;

    // 按 build-time 垂直位置排序（从上到下），保持预设的均匀分布
    tags.sort((a, b) => Number(a.dataset.y) - Number(b.dataset.y));

    const placed: { x: number; y: number; w: number; h: number }[] = [];

    function collides(box: {x:number;y:number;w:number;h:number}) {
      return placed.some(q =>
        box.x < q.x + q.w + GAP && box.x + box.w + GAP > q.x &&
        box.y < q.y + q.h + GAP && box.y + box.h + GAP > q.y
      );
    }

    tags.forEach((el) => {
      const w = el.offsetWidth, h = el.offsetHeight;
      const ox = (parseFloat(el.dataset.x!) / 100) * CW;
      const oy = (parseFloat(el.dataset.y!) / 100) * CH;
      let bestX = 0, bestY = 0, found = false;

      // 策略1：从初始位置黄金角螺旋搜索
      for (let t = 0; t < 500; t++) {
        const angle = t * 2.399;
        const r = 4 + t * 1.5;
        const x = Math.max(0, Math.min(CW - w, ox + Math.cos(angle) * r));
        const y = Math.max(0, Math.min(CH - h, oy + Math.sin(angle) * r));
        if (!collides({ x, y, w, h })) { bestX = x; bestY = y; found = true; break; }
      }

      // 策略2：扫描全容器找空位（从上到下、从左到右，步进 5px）
      if (!found) {
        for (let sy = 0; sy <= CH - h && !found; sy += 5) {
          for (let sx = 0; sx <= CW - w && !found; sx += 5) {
            if (!collides({ x: sx, y: sy, w, h })) { bestX = sx; bestY = sy; found = true; }
          }
        }
      }

      if (found) {
        placed.push({ x: bestX, y: bestY, w, h });
        el.style.left = `${(bestX / CW) * 100}%`;
        el.style.top  = `${(bestY / CH) * 100}%`;
      }
    });
  }
  resolveTagCloud();
  if (document.fonts?.ready) document.fonts.ready.then(resolveTagCloud);

</script>

<style>
  /* 移动/平板下隐藏右栏的搜索/标签云卡片的最末装饰，避免过满 */
  @media (max-width: 1023px) {
    .paper-card { border-radius: 1rem; }
  }
</style>
</BaseLayout>
