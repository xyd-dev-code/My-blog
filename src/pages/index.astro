---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE, filterTags } from '~/consts';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

function formatDate(d: Date) {
  return d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<BaseLayout>
  <!-- HERO -->
  <section class="relative overflow-hidden pt-16 pb-24 sm:pt-24 sm:pb-32">
    <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 text-center">
      <!-- 装饰小徽章 -->
      <div class="inline-flex items-center gap-2 rounded-full bg-white/80 backdrop-blur px-4 py-1.5 text-xs font-mono text-ink-500 shadow-paper border border-cloud-300 mb-8">
        <span class="h-1.5 w-1.5 rounded-full bg-leaf-500 animate-pulse"></span>
        <span>欢迎来到我的小角落 ☁️</span>
      </div>

      <h1 class="font-display text-5xl sm:text-7xl font-bold tracking-tight text-balance leading-[1.1]">
        <span class="text-ink-900">Hi, I'm </span>
        <span class="text-sky-700">{SITE.author}</span>
        <span class="text-ink-900">.</span>
        <br />
        <span class="text-ink-500 text-3xl sm:text-5xl font-medium font-serif italic">
          I write about
        </span>
        <br />
        <span class="text-sky-600 font-serif italic">things I learn.</span>
      </h1>

      <p class="mt-8 max-w-2xl mx-auto text-lg text-ink-700 leading-relaxed">
        这里是 <span class="font-semibold text-sky-700">{SITE.author}</span> 的个人技术博客。
        记录学习过程、踩过的坑、做过的项目。
      </p>

      <!-- 终端风 CTA -->
      <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
        <a
          href="/posts"
          class="group inline-flex items-center gap-2 rounded-full bg-sky-500 px-6 py-2.5 text-sm font-medium text-white shadow-paper hover:bg-sky-600 hover:shadow-paper-hover transition-[transform,box-shadow,background-color] duration-[220ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
        >
          翻开文章
          <span class="card-arrow">→</span>
        </a>
        <a
          href="/projects"
          class="group inline-flex items-center gap-2 rounded-full border border-cloud-300 bg-white/80 backdrop-blur px-6 py-2.5 text-sm font-medium text-ink-700 hover:border-sky-400 hover:text-sky-700 transition-[transform,box-shadow,border-color,color] duration-[220ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
        >
          看看项目
          <span class="card-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- LATEST POSTS -->
  <section class="relative mx-auto max-w-6xl px-4 sm:px-6 py-20">
    <div class="flex items-baseline justify-between mb-10">
      <div>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-ink-900">
          最近写的
        </h2>
        <p class="mt-2 text-sm text-ink-500 font-serif italic">recent posts</p>
      </div>
      <a
        href="/posts"
        class="hidden sm:inline-flex items-center gap-1.5 text-sm text-sky-600 hover:text-sky-700 transition-[color] duration-[120ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
      >
        所有文章 <span>→</span>
      </a>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {posts.map((post) => (
        <a
          href={`/posts/${post.id}`}
          data-tilt
          class="paper-card group block overflow-hidden transition-[transform] duration-[220ms] ease-[cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-1 relative"
        >
          <!-- 头图 -->
          <div class="h-36 relative overflow-hidden">
            {post.data.cover ? (
              <img
                src={post.data.cover}
                alt={post.data.title}
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500 ease-out"
                loading="eager"
                decoding="async"
                referrerpolicy="no-referrer"
              />
            ) : (
              <>
                <div
                  class="absolute inset-0"
                  style="background: linear-gradient(180deg, #bae6fd 0%, #e0f2fe 60%, #f0f9ff 100%);"
                />
                <svg
                  class="absolute bottom-0 left-0 w-full h-auto"
                  viewBox="0 0 400 100"
                  preserveAspectRatio="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path d="M0,60 Q100,30 200,50 T400,55 L400,100 L0,100 Z" fill="#7dd3fc" opacity="0.6" />
                  <path d="M0,75 Q100,55 200,70 T400,68 L400,100 L0,100 Z" fill="#38bdf8" opacity="0.5" />
                </svg>
              </>
            )}
            <div class="absolute top-3 left-3">
              <span class="tag-chip text-[10px]">{filterTags(post.data.tags ?? [])[0] ?? 'article'}</span>
            </div>
          </div>

          <div class="p-5">
            <div class="mb-2 flex items-center gap-2 text-xs text-ink-400">
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
            </div>
            <h3 class="font-display text-lg font-semibold text-ink-900 group-hover:text-sky-700 transition-[color] duration-[120ms] ease-[cubic-bezier(0.22,1,0.36,1)] line-clamp-2">
              {post.data.title}
            </h3>
            <p class="mt-2 text-sm text-ink-500 line-clamp-2 leading-relaxed">
              {post.data.description}
            </p>
            <div class="mt-4 inline-flex items-center gap-1 text-xs text-sky-600">
              继续阅读 <span class="card-arrow">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- 简约 CTA -->
  <section class="relative mx-auto max-w-3xl px-4 sm:px-6 pb-24">
    <div class="paper-card p-8 sm:p-10 text-center relative" data-tilt>
      <p class="text-ink-700 leading-relaxed">
        <span class="text-sky-600 font-medium">如果你是</span>
        <span class="text-sun-500 font-medium">工程师</span>：
      </p>
      <p class="mt-4 text-ink-700">
        去 <a href="/projects" class="paper-link">项目</a> 看看我做过什么，
        去 <a href="/posts" class="paper-link">文章</a> 了解我怎么想，
        或者去 <a href={SITE.github} target="_blank" rel="noopener" class="paper-link">GitHub</a> 直接找我。
      </p>
    </div>
  </section>
</BaseLayout>
